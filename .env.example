# Park King OS — Environment Variables
# Copy to .env and fill in your values

# ParkingPro credentials (same as Label Print Tool)
PK_URL=https://parkdirect24.parkingpro.de
PK_EMAIL=
PK_PASSWORD=

PSF_URL=https://parkshuttlefly.parkingpro.de
PSF_EMAIL=
PSF_PASSWORD=

# JWT Secret (auto-generated on Render)
JWT_SECRET=change-me-in-production

# Database path (default: data/parkking.db)
# DB_PATH=./data/parkking.db

# Port
PORT=3000
